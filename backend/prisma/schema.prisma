generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Safe {
  id           String      @id @default(cuid())
  passwordHash String
  createdAt    DateTime    @default(now())

  devices      TrustedDevice[]
  recoveryCodes RecoveryCode[]

  sources      Source[]
  tags         Tag[]
  digests      Digest[]
}

model TrustedDevice {
  id        String   @id @default(cuid())
  safeId    String
  safe      Safe     @relation(fields: [safeId], references: [id], onDelete: Cascade)
  tokenHash String   @unique // SHA-256 hash of the device token
  createdAt DateTime @default(now())
  lastUsed  DateTime @default(now())
}

model RecoveryCode {
  id        String   @id @default(cuid())
  safeId    String
  safe      Safe     @relation(fields: [safeId], references: [id], onDelete: Cascade)
  codeHash  String   @unique // SHA-256 hash of the recovery code
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Source {
  id           String      @id @default(cuid())
  safeId       String
  safe         Safe        @relation(fields: [safeId], references: [id], onDelete: Cascade)
  type         String      // "text", "url", "pdf", "file"
  title        String?
  originalUrl  String?
  rawText      String
  createdAt    DateTime    @default(now())
  lastAccessedAt DateTime  @default(now())
  chunks       Chunk[]
  tags         SourceTag[]
}

model Chunk {
  id           String      @id @default(cuid())
  sourceId     String
  source       Source      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  content      String
  chunkIndex   Int
  embedding    Unsupported("vector(768)")?
  createdAt    DateTime    @default(now())
}

model Tag {
  id           String      @id @default(cuid())
  safeId       String
  safe         Safe        @relation(fields: [safeId], references: [id], onDelete: Cascade)
  name         String
  sources      SourceTag[]

  @@unique([safeId, name])
}

model SourceTag {
  sourceId     String
  tagId        String
  source       Source      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  tag          Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([sourceId, tagId])
}

model Digest {
  id           String      @id @default(cuid())
  safeId       String
  safe         Safe        @relation(fields: [safeId], references: [id], onDelete: Cascade)
  content      String
  orphanedSourceIds String? // JSON string array of IDs
  createdAt    DateTime    @default(now())
}
