# Database
DATABASE_URL="postgresql://user:password@localhost:5432/recall"

# API Keys
ANTHROPIC_API_KEY="your-anthropic-key"
GEMINI_API_KEY="your-gemini-key"

# Security
APP_PASSWORD="your-secure-password"
CRON_SECRET="your-cron-secret"

# Permanent File Storage (Supabase)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_KEY="sb_secret_your_key_here"

# Auth
SESSION_SECRET="a-very-long-secret-key-at-least-32-chars"

# Cron
CRON_SECRET="secret-for-cron-job-org"

# Blob Storage (Optional for v1, but good to have)
BLOB_STORAGE_TOKEN="your-blob-token"
